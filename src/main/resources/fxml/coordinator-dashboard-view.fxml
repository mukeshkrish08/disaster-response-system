<?xml version="1.0" encoding="UTF-8"?>
<!--
  Coordinator dashboard.
   
-->
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.CoordinatorDashboardController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-wrap">
            <Label text="Coordinator dashboard" styleClass="hero"/>
            <Label text="Triage, assign teams and allocate resources for active incidents."
                   styleClass="lead"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Status:" styleClass="field-label"/>
                <ComboBox fx:id="filterCombo" onAction="#onRefresh"/>
                <Label text="Type:" styleClass="field-label"/>
                <ComboBox fx:id="typeFilterCombo" onAction="#onRefresh"/>
                <Label text="Strategy:" styleClass="field-label"/>
                <ComboBox fx:id="strategyCombo" onAction="#onStrategyChange"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻ Refresh" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
            </HBox>

            <TableView fx:id="incidentTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Code" prefWidth="140"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="140"/>
                    <TableColumn fx:id="scoreColumn" text="Score" prefWidth="80"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="assignedTeamColumn" text="Assigned team" prefWidth="220"/>
                    <TableColumn fx:id="locationColumn" text="Location" prefWidth="220"/>
                    <TableColumn fx:id="reportedColumn" text="Reported" prefWidth="160"/>
                </columns>
            </TableView>

            <HBox spacing="8" styleClass="button-row">
                <Button text="Open incident details" onAction="#onOpenDetails"
                        styleClass="btn"/>
                <Button text="Resources" onAction="#onResources"
                        styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
