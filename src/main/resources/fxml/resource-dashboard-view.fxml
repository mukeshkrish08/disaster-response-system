<?xml version="1.0" encoding="UTF-8"?>
<!--
  Resource Inventory dashboard (Feature 1).
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.ResourceDashboardController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Button text="← Back" onAction="#onBack"
                    styleClass="btn-secondary"/>
            <Region prefWidth="16"/>
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <Label text="Resource inventory" styleClass="hero"/>
            <Label text="Track availability across resource types. Allocate to incidents or send to maintenance / retirement as needed."
                   styleClass="lead" wrapText="true"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Filter type:" styleClass="field-helper"/>
                <ComboBox fx:id="typeFilterCombo" onAction="#onRefresh"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻ Refresh" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
                <Button text="+ Add resource" onAction="#onAddResource"
                        styleClass="btn"/>
            </HBox>

            <TableView fx:id="resourcesTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Code" prefWidth="140"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="220"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="140"/>
                    <TableColumn fx:id="totalColumn" text="Total" prefWidth="80"/>
                    <TableColumn fx:id="availableColumn" text="Avail" prefWidth="80"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                </columns>
            </TableView>

            <HBox spacing="8" styleClass="button-row">
                <Button text="Allocate to incident" onAction="#onAllocate"
                        styleClass="btn"/>
                <Button text="View allocations" onAction="#onViewAllocations"
                        styleClass="btn-secondary"/>
                <Button text="Return allocation" onAction="#onReturnAllocation"
                        styleClass="btn-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⚙ To maintenance"
                        onAction="#onSendToMaintenance"
                        styleClass="btn-secondary"/>
                <Button text="✓ From maintenance"
                        onAction="#onReturnFromMaintenance"
                        styleClass="btn-secondary"/>
                <Button text="✕ Retire"
                        onAction="#onRetireResource"
                        styleClass="btn-signout"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
