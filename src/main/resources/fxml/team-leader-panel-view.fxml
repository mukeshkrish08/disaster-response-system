<?xml version="1.0" encoding="UTF-8"?>
<!--
  Team leader panel.
  Shows incidents assigned to this leader's team plus the recovery
  tasks owned by this leader. Server filters everything by the
  leader's team_pk so two different team leaders see different rows.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.TeamLeaderPanelController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-wrap">
            <Label fx:id="teamHeading" text="Team leader panel"
                   styleClass="hero"/>
            <Label text="Track incidents assigned to your team and the recovery tasks you own."
                   styleClass="lead" wrapText="true"/>

            <Label text="Incidents assigned to my team" styleClass="section-heading"/>

            <TableView fx:id="assignedIncidentsTable" prefHeight="320"
                       VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="assnIncidentColumn" text="Incident" prefWidth="180"/>
                    <TableColumn fx:id="assnRoleColumn" text="Role" prefWidth="140"/>
                    <TableColumn fx:id="assnStatusColumn" text="Status" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox spacing="8" styleClass="button-row">
                <Button text="Start response" onAction="#onStartResponse"
                        styleClass="btn"/>
                <Button text="Complete response" onAction="#onCompleteResponse"
                        styleClass="btn"/>
                <Button text="View incident" onAction="#onViewIncident"
                        styleClass="btn-secondary"/>
                <Button text="↻ Refresh" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
            </HBox>

            <Label text="My recovery tasks" styleClass="section-heading"/>

            <TableView fx:id="myTasksTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="taskCodeColumn" text="Task" prefWidth="180"/>
                    <TableColumn fx:id="taskIncidentColumn" text="Incident" prefWidth="180"/>
                    <TableColumn fx:id="taskStatusColumn" text="Status" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox spacing="8" styleClass="button-row">
                <Button text="Update task" onAction="#onUpdateTask"
                        styleClass="btn"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
