<?xml version="1.0" encoding="UTF-8"?>
<!--
  Citizen dashboard.
   
-->
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.CitizenDashboardController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-wrap">
            <Label fx:id="welcomeLabel" text="Welcome" styleClass="hero"/>
            <Label text="Track the disasters you've reported and submit new reports."
                   styleClass="lead"/>

            <HBox spacing="8">
                <Button text="+ Report a new incident"
                        onAction="#onReportNew"
                        styleClass="btn"/>
                <Button text="↻ Refresh"
                        onAction="#onRefresh"
                        styleClass="btn-secondary"/>
                <Button fx:id="withdrawButton"
                        text="✕ Withdraw selected"
                        onAction="#onWithdraw"
                        styleClass="btn-secondary"/>
            </HBox>

            <Label text="My reports" styleClass="section-heading"/>

            <TableView fx:id="myReportsTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Code" prefWidth="160"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="160"/>
                    <TableColumn fx:id="reportedColumn" text="Reported" prefWidth="180"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label" text=""/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
