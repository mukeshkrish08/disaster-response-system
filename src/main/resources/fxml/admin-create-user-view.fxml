<?xml version="1.0" encoding="UTF-8"?>
<!--
  Admin: create staff user.
  Role determines whether the Department combo appears: AGENCY_REP
  and TEAM_LEADER require a department; COORDINATOR and ADMIN must
  not have one. CITIZEN is forbidden here (citizens self-register).
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.AdminCreateUserController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Button text="← Back" onAction="#onCancel"
                    styleClass="btn-secondary"/>
            <Region prefWidth="16"/>
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" maxWidth="640">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="Create staff user" styleClass="hero"/>
            <Label text="Provision a new staff account. Citizens self-register from the login screen - they cannot be created here."
                   styleClass="lead" wrapText="true"/>

            <GridPane hgap="16" vgap="12" styleClass="form-grid">
                <Label text="Full name *" styleClass="field-helper"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="fullNameField" prefWidth="280"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Email *" styleClass="field-helper"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="emailField" prefWidth="280"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Role *" styleClass="field-helper"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="roleCombo" prefWidth="280"
                          GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label fx:id="departmentLabel" text="Department *"
                       styleClass="field-helper"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <ComboBox fx:id="departmentCombo" prefWidth="280"
                          GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Password *" styleClass="field-helper"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <PasswordField fx:id="passwordField" prefWidth="280"
                               GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                <Label text="Confirm password *" styleClass="field-helper"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <PasswordField fx:id="confirmPasswordField" prefWidth="280"
                               GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            </GridPane>

            <Label text="Password must be at least 8 characters with mixed case, a digit, and a special character."
                   styleClass="field-helper"/>

            <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="button-row">
                <Button text="Cancel" onAction="#onCancel"
                        cancelButton="true" styleClass="btn-secondary"/>
                <Button fx:id="createButton" text="Create staff user" onAction="#onCreate"
                        defaultButton="true" styleClass="btn"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
