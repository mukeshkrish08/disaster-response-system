<?xml version="1.0" encoding="UTF-8"?>
<!--
  Report incident form.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.ReportIncidentController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox styleClass="content-wrap">
                <Label text="Report a new incident" styleClass="hero"/>
                <Label text="Tell us what's happening and where so emergency coordinators can dispatch the right response."
                       styleClass="lead" wrapText="true"/>

                <GridPane hgap="16" vgap="12" styleClass="form-grid">
                    <Label text="Disaster type *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="disasterTypeCombo"
                              GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Location *" styleClass="field-helper"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="locationCombo" prefWidth="280"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="People affected *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Spinner fx:id="peopleAffectedSpinner"
                             GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                    <Label text="Property risk" styleClass="field-helper"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="propertyRiskCombo"
                              GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Contact phone *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="contactPhoneField"
                               promptText="04XX XXX XXX or 02 XXXX XXXX"
                               prefWidth="280"
                               GridPane.columnIndex="0" GridPane.rowIndex="5"
                               GridPane.columnSpan="2"/>
                    <Label text="So the coordinator can call you back about this report."
                           styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="6"
                           GridPane.columnSpan="2"/>
                </GridPane>

                <Label text="What is happening? *" styleClass="field-helper"/>
                <TextArea fx:id="descriptionArea" prefRowCount="6"
                          wrapText="true"/>
                <Label fx:id="charCountLabel" text="0 / 1000 characters"
                       styleClass="field-helper"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="8" alignment="CENTER_RIGHT"
                      styleClass="button-row">
                    <Button text="Cancel" onAction="#onCancel"
                            cancelButton="true" styleClass="btn-secondary"/>
                    <Button text="Submit report" onAction="#onSubmit"
                            defaultButton="true" styleClass="btn"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel"
                   text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
