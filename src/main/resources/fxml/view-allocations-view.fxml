<?xml version="1.0" encoding="UTF-8"?>
<!--
  View allocations for a selected incident. Feature 1.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.ViewAllocationsController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Button text="← Back" onAction="#onBack"
                    styleClass="btn-secondary"/>
            <Region prefWidth="16"/>
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="20" right="28" bottom="20" left="28"/>
            </padding>

            <Label text="Allocations by incident" styleClass="hero"/>
            <Label text="Review which resources are currently committed to an incident."
                   styleClass="lead"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Incident:" styleClass="field-label"/>
                <ComboBox fx:id="incidentCombo" prefWidth="320"
                          onAction="#onIncidentChange"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻ Refresh" onAction="#onIncidentChange"
                        styleClass="btn-secondary"/>
            </HBox>

            <TableView fx:id="allocationsTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Allocation"
                                 prefWidth="160"/>
                    <TableColumn fx:id="resourceColumn" text="Resource"
                                 prefWidth="220"/>
                    <TableColumn fx:id="quantityColumn" text="Qty"
                                 prefWidth="70"/>
                    <TableColumn fx:id="allocatedByColumn" text="Allocated by"
                                 prefWidth="160"/>
                    <TableColumn fx:id="allocatedAtColumn" text="When"
                                 prefWidth="160"/>
                    <TableColumn fx:id="returnedColumn" text="Returned?"
                                 prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
