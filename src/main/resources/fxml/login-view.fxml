<?xml version="1.0" encoding="UTF-8"?>
<!--
  Login screen.
  Uses BorderPane so the card sits in the true vertical and horizontal
  centre of the window. The bottom status bar surfaces the connection
  state without crowding the form.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.LoginController"
            styleClass="page-container">

    <center>
        <VBox styleClass="centered-card-wrapper">
            <VBox alignment="CENTER" spacing="4">
                <Label text="Disaster Response System" styleClass="hero"/>
                <Label text="Emergency Management Platform" styleClass="lead"/>
            </VBox>

            <VBox spacing="12" maxWidth="380" styleClass="card">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <VBox spacing="4">
                    <Label text="Email" styleClass="field-helper"/>
                    <TextField fx:id="emailField"
                               promptText="you@drs.local"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Password" styleClass="field-helper"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Your password"/>
                </VBox>

                <Label fx:id="errorLabel"
                       text=""
                       styleClass="field-error"/>

                <Button fx:id="signInButton"
                        text="Sign in"
                        defaultButton="true"
                        maxWidth="Infinity"
                        styleClass="btn"
                        onAction="#onSignIn"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="New citizen?" styleClass="field-helper"/>
                    <Button text="Create account"
                            onAction="#onCreateAccount"
                            styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label" text=""/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel"
                   text="● Ready"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
