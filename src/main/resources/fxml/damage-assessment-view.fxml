<?xml version="1.0" encoding="UTF-8"?>
<!--
  Damage assessment form (Feature 2).
  Wrapped in BorderPane with flush-edge header and footer, but the
  form content itself sits inside a ScrollPane in the centre so long
  forms remain reachable on small windows.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.DamageAssessmentController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox styleClass="content-wrap">
                <HBox spacing="8">
                    <Button text="← Back" onAction="#onCancel"
                            styleClass="btn-secondary"/>
                </HBox>

                <Label fx:id="pageTitle" text="Damage assessment"
                       styleClass="hero"/>

                <Label text="Previous assessments" styleClass="section-heading"/>
                <TableView fx:id="previousAssessmentsTable"
                           prefHeight="200" styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="timeColumn" text="When"
                                     prefWidth="160"/>
                        <TableColumn fx:id="assessorColumn" text="Assessor"
                                     prefWidth="160"/>
                        <TableColumn fx:id="buildingColumn" text="Building"
                                     prefWidth="160"/>
                        <TableColumn fx:id="casualtyColumn" text="Casualties"
                                     prefWidth="100"/>
                    </columns>
                </TableView>

                <Label text="New assessment" styleClass="section-heading"/>
                <GridPane hgap="16" vgap="12" styleClass="form-grid">
                    <Label text="Building damage *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="buildingDamageCombo"
                              GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Road status *" styleClass="field-helper"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="roadStatusCombo"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Power status *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="powerStatusCombo"
                              GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                    <Label text="Water status *" styleClass="field-helper"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="waterStatusCombo"
                              GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Casualty estimate *"
                           styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Spinner fx:id="casualtyEstimateSpinner"
                             GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                </GridPane>

                <Label text="Notes (encrypted at rest)"
                       styleClass="field-helper"/>
                <TextArea fx:id="notesArea" prefRowCount="4" wrapText="true"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="8" alignment="CENTER_RIGHT"
                      styleClass="button-row">
                    <Button text="Cancel" onAction="#onCancel"
                            cancelButton="true" styleClass="btn-secondary"/>
                    <Button text="Save assessment" onAction="#onSave"
                            defaultButton="true" styleClass="btn"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel"
                   text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
