<?xml version="1.0" encoding="UTF-8"?>
<!--
  Admin panel.
  Per-tab action buttons (Add / Deactivate selected) keep entity
  management scoped to the tab the admin is viewing. A new Locations
  tab is added between Teams and Resources.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.AdminPanelController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-wrap">
            <Label text="Admin panel" styleClass="hero"/>
            <Label text="Manage users, departments, teams, locations, resources, and the audit chain. Soft delete (deactivate) preserves history; rows are never physically removed."
                   styleClass="lead" wrapText="true"/>

            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button text="↻ Refresh all" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
            </HBox>

            <TabPane fx:id="adminTabs" VBox.vgrow="ALWAYS"
                     styleClass="card">
                <tabs>

                    <Tab text="Users" closable="false">
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Citizens self-register; staff are admin-provisioned."
                                       styleClass="field-helper"
                                       wrapText="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="+ Add staff user"
                                        onAction="#onAddUser"
                                        styleClass="btn"/>
                                <Button text="✕ Deactivate selected"
                                        onAction="#onDeactivateUser"
                                        styleClass="btn-secondary"/>
                            </HBox>
                            <ListView fx:id="usersList" VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                    <Tab text="Departments" closable="false">
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Add new departments (Fire, Hospital, Police, Utility, etc.) and retire old ones."
                                       styleClass="field-helper"
                                       wrapText="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="+ Add department"
                                        onAction="#onAddDepartment"
                                        styleClass="btn"/>
                                <Button text="✕ Deactivate selected"
                                        onAction="#onDeactivateDepartment"
                                        styleClass="btn-secondary"/>
                            </HBox>
                            <ListView fx:id="departmentsList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                    <Tab text="Teams" closable="false">
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Add response teams within a department."
                                       styleClass="field-helper"
                                       wrapText="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="+ Add team"
                                        onAction="#onAddTeam"
                                        styleClass="btn"/>
                                <Button text="✕ Deactivate selected"
                                        onAction="#onDeactivateTeam"
                                        styleClass="btn-secondary"/>
                            </HBox>
                            <ListView fx:id="teamsList" VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                    <Tab text="Locations" closable="false">
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Geographic anchors for incident reports. Deactivating hides a location from new reports but keeps history intact."
                                       styleClass="field-helper"
                                       wrapText="true"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="+ Add location"
                                        onAction="#onAddLocation"
                                        styleClass="btn"/>
                                <Button text="✕ Deactivate selected"
                                        onAction="#onDeactivateLocation"
                                        styleClass="btn-secondary"/>
                            </HBox>
                            <ListView fx:id="locationsList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                    <Tab text="Resources" closable="false">
                        <VBox spacing="10">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12"/>
                            </padding>
                            <Label text="Read-only view. Manage resources from the Resources dashboard accessible to coordinators."
                                   styleClass="field-helper" wrapText="true"/>
                            <ListView fx:id="resourcesList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                    <Tab text="Audit log" closable="false">
                        <VBox spacing="14">
                            <padding>
                                <Insets top="14" right="14" bottom="14" left="14"/>
                            </padding>
                            <Label text="Audit Chain - Non-Repudiation"
                                   styleClass="section-heading"/>
                            <Label text="Every privileged action is logged with a SHA-256 hash linked to the previous entry. Click below to verify the chain is unbroken."
                                   styleClass="field-helper" wrapText="true"/>
                            <HBox spacing="14" alignment="CENTER_LEFT">
                                <Button text="✓ Verify audit chain"
                                        onAction="#onVerifyChain"
                                        styleClass="btn"/>
                                <Label fx:id="verifyChainStatusLabel"
                                       styleClass="verify-ok"/>
                            </HBox>
                            <Label text="Audit entries (latest first)"
                                   styleClass="field-label"/>
                            <ListView fx:id="auditEntriesList"
                                      VBox.vgrow="ALWAYS"
                                      styleClass="data-table"/>
                        </VBox>
                    </Tab>

                </tabs>
            </TabPane>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
