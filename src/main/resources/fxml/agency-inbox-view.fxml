<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agency representative inbox.
  Lists notifications addressed to this rep's department; the server
  filters by department_pk so two agencies do not see each other's
  notifications. Acknowledging marks status=ACKNOWLEDGED.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.AgencyInboxController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="content-wrap">
            <Label text="Agency inbox" styleClass="hero"/>
            <Label text="Notifications routed to your department from coordinator dispatches. Acknowledge after action."
                   styleClass="lead" wrapText="true"/>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="pendingCountLabel" text="Pending: 0"
                       styleClass="section-heading"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="↻ Refresh" onAction="#onRefresh"
                        styleClass="btn-secondary"/>
            </HBox>

            <TableView fx:id="notificationsTable" VBox.vgrow="ALWAYS"
                       styleClass="data-table">
                <columns>
                    <TableColumn fx:id="timeColumn" text="Time" prefWidth="140"/>
                    <TableColumn fx:id="incidentColumn" text="Incident" prefWidth="180"/>
                    <TableColumn fx:id="messageColumn" text="Message" prefWidth="400"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox spacing="8" styleClass="button-row">
                <Button text="Acknowledge" onAction="#onAcknowledge"
                        styleClass="btn"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
