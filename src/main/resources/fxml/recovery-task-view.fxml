<?xml version="1.0" encoding="UTF-8"?>
<!--
  Recovery tasks view (Feature 2).
  Wrapped in a BorderPane so the header is flush-edge and the long
  form is reachable via ScrollPane in the centre.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.RecoveryTaskController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox styleClass="content-wrap">
                <HBox spacing="8">
                    <Button text="← Back" onAction="#onCancel"
                            styleClass="btn-secondary"/>
                </HBox>

                <Label fx:id="pageTitle" text="Recovery tasks"
                       styleClass="hero"/>

                <Label text="Existing tasks" styleClass="section-heading"/>
                <TableView fx:id="existingTasksTable" prefHeight="240"
                           styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="taskCodeColumn" text="Task"
                                     prefWidth="160"/>
                        <TableColumn fx:id="taskTypeColumn" text="Type"
                                     prefWidth="180"/>
                        <TableColumn fx:id="taskStatusColumn" text="Status"
                                     prefWidth="140"/>
                        <TableColumn fx:id="taskDepartmentColumn" text="Department"
                                     prefWidth="160"/>
                    </columns>
                </TableView>

                <HBox spacing="8" styleClass="button-row">
                    <Button text="Update status" onAction="#onUpdateStatus"
                            styleClass="btn-secondary"/>
                </HBox>

                <Label text="Create new task" styleClass="section-heading"/>
                <GridPane hgap="16" vgap="12" styleClass="form-grid">
                    <Label text="Type *" styleClass="field-helper"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="taskTypeCombo"
                              GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Responsible department / agency *"
                           styleClass="field-helper"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="departmentCombo" prefWidth="320"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <Label text="Description *" styleClass="field-helper"/>
                <TextArea fx:id="descriptionArea" prefRowCount="3"
                          wrapText="true"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="8" alignment="CENTER_RIGHT"
                      styleClass="button-row">
                    <Button text="Cancel" onAction="#onCancel"
                            cancelButton="true" styleClass="btn-secondary"/>
                    <Button text="Create task" onAction="#onCreateTask"
                            defaultButton="true" styleClass="btn"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel"
                   text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
