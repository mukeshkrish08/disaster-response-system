<?xml version="1.0" encoding="UTF-8"?>
<!--
  Admin: add a new response team.
  Team belongs to a department. Latitude/longitude are the team's
  home base coordinates - the Haversine distance from this point to
  the incident drives team suggestions.
   
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="drs.client.controller.AdminAddTeamController"
            styleClass="page-container">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <Button text="← Back" onAction="#onCancel"
                    styleClass="btn-secondary"/>
            <Region prefWidth="16"/>
            <Label text="Disaster Response System"
                   styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox styleClass="header-user-info">
                <Label fx:id="userNameLabel"
                       styleClass="header-user-name"/>
                <Label fx:id="userRoleLabel"
                       styleClass="header-user-role"/>
            </VBox>
            <Region prefWidth="16"/>
            <Button text="Sign out" onAction="#onSignOut"
                    styleClass="btn-signout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" maxWidth="640">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="Add response team" styleClass="hero"/>
            <Label text="A team belongs to a department. Latitude / longitude are the team's home base - these drive distance-based dispatch."
                   styleClass="lead" wrapText="true"/>

            <GridPane hgap="16" vgap="12" styleClass="form-grid">
                <Label text="Team name *" styleClass="field-helper"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="teamNameField" prefWidth="280"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Department *" styleClass="field-helper"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <ComboBox fx:id="departmentCombo" prefWidth="280"
                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Latitude *" styleClass="field-helper"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="latitudeField" prefWidth="280"
                           promptText="e.g. -33.8688"
                           GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="Longitude *" styleClass="field-helper"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="longitudeField" prefWidth="280"
                           promptText="e.g. 151.2093"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>

            <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="button-row">
                <Button text="Cancel" onAction="#onCancel"
                        cancelButton="true" styleClass="btn-secondary"/>
                <Button fx:id="addTeamButton" text="Add team" onAction="#onAdd"
                        defaultButton="true" styleClass="btn"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="status-bar">
            <Label fx:id="statusLabel" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectionStatusLabel" text="● Connected"
                   styleClass="net-online"/>
        </HBox>
    </bottom>
</BorderPane>
